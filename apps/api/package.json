{
  "name": "@bomberman/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=dist --minify --external @prisma/client",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "start": "bun run dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema prisma/schema.prisma --force",
    "db:seed": "bun run prisma/seed.ts",
    "db:seed:users": "bun run prisma/seed-users.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@bomberman/types": "workspace:*",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/jwt": "^1.1.1",
    "@elysiajs/swagger": "^1.1.6",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "5.22.0",
    "@prisma/client": "^5.22.0",
    "elysia": "^1.1.27",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@bomberman/config": "workspace:*",
    "@types/node": "^22.10.5",
    "bun-types": "^1.3.9",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  }
}
