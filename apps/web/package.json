    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "next": "15.1.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@bomberman/config": "workspace:*",
